import torch
import torch.nn.functional as F
import os

from typing import Optional, Union, Tuple
from PIL import Image
import cv2
import numpy as np
from peft import PeftModel


from diffusers import (
    StableDiffusionImg2ImgPipeline,
    StableDiffusionControlNetImg2ImgPipeline,
    ControlNetModel,
    DDIMScheduler,
)


class PixelArtGenerator:
    def __init__(
        self,
        base_model_path: str = "models/sd15",
        lora_dir: str = "models/lora/1bit", 
        controlnet_path: str = "models/controlnet_canny",
        device: str = "cuda",
        dtype: torch.dtype = torch.float16
    ):
        self.device = device
        self.dtype = dtype

        

        print(f"--- Step 1: Loading Base SD Model ---")
        self.pipe = StableDiffusionImg2ImgPipeline.from_pretrained(
            base_model_path,
            torch_dtype=dtype,
            safety_checker=None,
            requires_safety_checker=False
        ).to(device)

        
        print(f"--- Step 2: Loading LoRA via PEFT ---")
        # 这种方式比手动修改前缀更稳定，能确保 1-bit 语义被触发
        try:
            self.pipe.unet = PeftModel.from_pretrained(
                self.pipe.unet, 
                lora_dir, 
                adapter_name="pixel_lora"
            ).to(device)
            print("Successfully loaded LoRA weights via PEFT.")
        except Exception as e:
            print(f"LoRA Load Error: {e}")
            print("Ensure adapter_config.json and adapter_model.safetensors exist.")
        

        self.pipe.scheduler = DDIMScheduler.from_config(
            self.pipe.scheduler.config,
            rescale_betas_zero_snr=True,
            timestep_spacing="trailing"
        )

        
        print(f" --- Step 3: Loading ControlNet ---")
        self.controlnet = ControlNetModel.from_pretrained(
            controlnet_path, torch_dtype=dtype
        ).to(device)

        self.controlnet_pipe = StableDiffusionControlNetImg2ImgPipeline(
            vae=self.pipe.vae,
            text_encoder=self.pipe.text_encoder,
            tokenizer=self.pipe.tokenizer,
            unet=self.pipe.unet,
            controlnet=self.controlnet,
            scheduler=self.pipe.scheduler,
            feature_extractor=None,
            safety_checker=None,
            requires_safety_checker=False
        ).to(device)


    def grid_quantization_callback(self, pipe, step_index, timestep, callback_kwargs):
        if step_index < 5:
            return callback_kwargs

        latents = callback_kwargs["latents"]
        num_steps = pipe.num_timesteps # 总步数

        with torch.enable_grad():
            lat_g = latents.detach().clone().requires_grad_(True)
        

        # --- 1. 计算动态引导强度 ---
        # 随时间衰减：前期需要强引导定型，后期需要弱引导微调
        # 进度从 0 到 1
            progress = step_index / num_steps
        # 初始强度 0.15，结束强度 0.05
            current_strength = 0.15 * (1 - progress) + 0.05 * progress

    
        # --- 2. 目标构建 ---
            grid_size = 2
            s = lat_g.shape
            target = F.avg_pool2d(lat_g, kernel_size=grid_size, stride=grid_size)

        # 强化 1-bit 偏置：使用更陡峭的激活函数
        # 这里的 3.0 是对比度拉伸系数，值越大越倾向于极端的黑白
            target = torch.tanh(target * 3.0) 
            target = F.interpolate(target, size=(s[2], s[3]), mode='nearest')

    
        # --- 3. 计算梯度与标准化 ---
            loss = F.mse_loss(lat_g, target)
            loss.backward()

            if lat_g.grad is not None:
            # 关键优化：梯度标准化
            # 这样无论梯度绝对值多大，我们每一步移动的步长都是受控的
                grad_dir = lat_g.grad / (torch.norm(lat_g.grad) + 1e-8)
                new_latents = latents - current_strength * grad_dir
            else:
                new_latents = latents


        callback_kwargs["latents"] = new_latents.detach()
        return callback_kwargs

    def post_process_1bit(self, image: Image.Image, pixel_size: int = 8) -> Image.Image:
        # 仅作为对比 baseline 的后处理逻辑
        gray = image.convert('L')
        img_array = np.array(gray)
        binary = ((img_array > 127) * 255).astype(np.uint8)
        binary_img = Image.fromarray(binary, mode='L').convert('RGB')
        

        w, h = binary_img.size
        small = binary_img.resize((max(1, w // pixel_size), max(1, h // pixel_size)), Image.NEAREST)
        return small.resize((w, h), Image.NEAREST)



    @torch.no_grad() # 核心：不要用 inference_mode，否则 callback 内部无法启用 grad
    def generate(
        self,
        image_path: str,
        prompt: str = "1bit pixel art, b&w, pure black and white, nes graphics, sharp lines, no grayscale",
        negative_prompt: str = "color, gradient, grey, blurry, smooth, text, artifacts",
        strength: float = 0.75,
        controlnet_scale: float = 0.8,
        guidance_scale: float = 12.0, # 配合 LoRA 效果的高 CFG
        seed: int = 42
    ) -> Tuple[Image.Image, Image.Image]:

        
        init_image = Image.open(image_path).convert("RGB")
        w, h = init_image.size
        init_image = init_image.resize(((w // 8) * 8, (h // 8) * 8))
        

        img_array = np.array(init_image)
        gray = cv2.cvtColor(img_array, cv2.COLOR_RGB2GRAY)
        edges = cv2.Canny(gray, 100, 200)
        canny_image = Image.fromarray(cv2.cvtColor(edges, cv2.COLOR_GRAY2RGB))
        

        generator = torch.Generator(device=self.device).manual_seed(seed)
        print(f"Running Native 1-bit Pixelation (CFG: {guidance_scale})...")
        raw_result = self.controlnet_pipe(
            prompt=prompt,
            negative_prompt=negative_prompt,
            image=init_image,
            control_image=canny_image.resize(init_image.size),
            strength=strength,
            num_inference_steps=30,
            guidance_scale=guidance_scale,
            controlnet_conditioning_scale=controlnet_scale,
            generator=generator,
            callback_on_step_end=self.grid_quantization_callback,
            callback_on_step_end_tensor_inputs=["latents"]
        ).images[0]


        # 如果我们的研究成功，raw_result 本身就应该是 1-bit 像素化的
        processed_result = self.post_process_1bit(raw_result, pixel_size=8)
        return raw_result, processed_result


def main():
    base_dir = "/root/autodl-tmp/SD-pixelization-2"
    
    gen = PixelArtGenerator(
        base_model_path=f"{base_dir}/models/sd15",
        lora_dir=f"{base_dir}/models/lora/1bit", 
        controlnet_path=f"{base_dir}/models/controlnet_canny"
    )


    # 这里我们调节参数：提高 CFG 到 12.0 以上，配合 LoRA 强制黑白
    raw, final = gen.generate(
        image_path=f"{base_dir}/input.png",
        strength=0.75,           
        controlnet_scale=0.8,    
        guidance_scale=12.0
    )


    raw.save(f"{base_dir}/output_raw.png")
    final.save(f"{base_dir}/output_final.png")
    print(f"Experiment complete. Check output_raw.png for native results.")



if __name__ == "__main__":
    main()
